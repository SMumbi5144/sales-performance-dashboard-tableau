          <datasource-dependencies datasource='federated.0c2b9on1gvkbu012eh3pb0r9xuzw'>
            <column caption='PY Sales ' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[CY Sales (copy)_0944498649980930]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 0944498650750980]-1 THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='CY Sales' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_0944498649657344]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 0944498650750980] THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='%Diff Sales' datatype='real' default-format='*▲ 0.00%; ▼ -0.00%;' name='[Calculation_0944498651910149]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0944498649657344])- SUM([CY Sales (copy)_0944498649980930]))/ SUM([CY Sales (copy)_0944498649980930])' />
            </column>
            <column caption='Min/Max Sales' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_0944498656239622]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Calculation_0944498649657344])= WINDOW_MAX(SUM([Calculation_0944498649657344])) &#13;&#10;THEN SUM([Calculation_0944498649657344])&#13;&#10;ELSEIF SUM([Calculation_0944498649657344])= WINDOW_MIN(SUM([Calculation_0944498649657344])) &#13;&#10;THEN SUM([Calculation_0944498649657344])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='{SUM([CY Sales])}' datatype='real' name='[Calculation_0944498658799627]' role='measure' type='quantitative' user:unnamed='KPI Sales'>
