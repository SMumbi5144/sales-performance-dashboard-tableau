              <calculation class='tableau' formula='IF SUM([Calculation_0944498666344463]) = WINDOW_MAX(SUM([Calculation_0944498666344463]))&#13;&#10;THEN SUM([Calculation_0944498666344463])&#13;&#10;ELSEIF SUM([Calculation_0944498666344463]) = WINDOW_MIN(SUM([Calculation_0944498666344463]))&#13;&#10;THEN SUM([Calculation_0944498666344463])&#13;&#10;END'>
