            <column caption='CY Orders' datatype='string' name='[Calculation_0703981109325824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 0944498650750980] THEN [Order ID]&#13;&#10;END' />
            </column>
            <column caption='PY Orders' datatype='string' name='[Calculation_0703981109993474]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 0944498650750980]-1 THEN [Order ID]&#13;&#10;END' />
            </column>
            <column caption='%Diff Orders' datatype='real' name='[Calculation_0703981110530051]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(COUNTD([Calculation_0703981109325824]) - COUNTD([Calculation_0703981109993474])) / COUNTD([Calculation_0703981109993474])' />
            </column>
            <column caption='Min/Max Orders' datatype='integer' name='[Calculation_0703981110706180]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF COUNTD([Calculation_0703981109325824]) = WINDOW_MAX(COUNTD([Calculation_0703981109325824]))&#13;&#10;THEN COUNTD([Calculation_0703981109325824])&#13;&#10;ELSEIF COUNTD([Calculation_0703981109325824]) = WINDOW_MIN(COUNTD([Calculation_0703981109325824]))&#13;&#10;THEN COUNTD([Calculation_0703981109325824])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='{COUNTD([CY Orders])}' datatype='integer' name='[Calculation_0703981113368581]' role='measure' type='quantitative' user:unnamed='KPI Orders'>
